library(vegan)
library(ggplot2)
library(dplyr)
BiocManager::install("dplyr")
library(dplyr)
BiocManager::install("vegan")
BiocManager::install("vegan")
BiocManager::install("ggplot2")
BiocManager::install("tidyr")
BiocManager::install("dplyr")
BiocManager::install("tibble")
BiocManager::install("readr")
BiocManager::install("readr")
BiocManager::install("dada2")
library(dada2)
library(phyloseq)
library(vegan)
library(ggplot2)
library(dplyr)
library(tidyr)
library(tibble)
library(readr)
path <- "D:\Dixcy"
path <- "D:/Dixcy"
# If using WSL R, use:
# path <- "/mnt/d/Dixcy"
fnFs <- sort(list.files(path, pattern = "_1.fastq.gz", full.names = TRUE))
fnRs <- sort(list.files(path, pattern = "_2.fastq.gz", full.names = TRUE))
fnFs
fnRs
sample.names <- sapply(strsplit(basename(fnFs), "_"), `[`, 1)
sample.names
plotQualityProfile(fnFs[1:2])
plotQualityProfile(fnRs[1:2])
filt_path <- file.path(path, "filtered")
dir.create(filt_path, showWarnings = FALSE)
filtFs <- file.path(filt_path, paste0(sample.names, "_F_filt.fastq.gz"))
filtRs <- file.path(filt_path, paste0(sample.names, "_R_filt.fastq.gz"))
out <- filterAndTrim(
fnFs, filtFs,
fnRs, filtRs,
truncLen = c(240, 200),
maxN = 0,
maxEE = c(2, 2),
truncQ = 2,
rm.phix = TRUE,
compress = TRUE,
multithread = TRUE
)
out
out <- filterAndTrim(
fnFs, filtFs,
fnRs, filtRs,
truncLen = c(240, 200),
maxN = 0,
maxEE = c(2, 2),
truncQ = 2,
rm.phix = TRUE,
compress = TRUE,
multithread = FALSE
)
out
filter_summary <- as.data.frame(out)
filter_summary$Percent_retained <- round(
filter_summary$reads.out / filter_summary$reads.in * 100, 2
)
filter_summary
write.csv(filter_summary, "filtering_summary.csv")
errF <- learnErrors(filtFs, multithread = FALSE)
errR <- learnErrors(filtRs, multithread = FALSE)
plotErrors(errF, nominalQ = TRUE)
plotErrors(errR, nominalQ = TRUE)
dadaFs <- dada(filtFs, err = errF, multithread = FALSE)
dadaRs <- dada(filtRs, err = errR, multithread = FALSE)
dadaFs[[1]]
dadaRs[[1]]
mergers <- mergePairs(
dadaFs, filtFs,
dadaRs, filtRs,
verbose = TRUE
)
head(mergers[[1]])
seqtab <- makeSequenceTable(dadaFs)
dim(seqtab)
table(nchar(getSequences(seqtab)))
seqtab.nochim <- removeBimeraDenovo(
seqtab,
method = "consensus",
multithread = FALSE,
verbose = TRUE
)
dim(seqtab.nochim)
sum(seqtab.nochim) / sum(seqtab)
write.csv(seqtab.nochim, "ASV_table_nochim_forward_only.csv")
saveRDS(seqtab.nochim, "seqtab_nochim_forward_only.rds")
getN <- function(x) sum(getUniques(x))
track <- cbind(
input = out[,1],
filtered = out[,2],
denoisedF = sapply(dadaFs, getN),
nonchim = rowSums(seqtab.nochim)
)
rownames(track) <- sample.names
track
write.csv(track, "read_tracking_forward_only.csv")
#Download SILVA taxonomy database
silva_nr99_v138.1_train_set.fa.gz
taxa <- assignTaxonomy(
seqtab.nochim,
"silva_nr99_v138.1_train_set.fa.gz",
multithread = FALSE
)
getwd()
list.files()
setwd("D:/Dixcy")
list.files()
taxa <- assignTaxonomy(
seqtab.nochim,
"silva_nr99_v138.1_train_set.fa.gz",
multithread = FALSE
)
taxa.print <- taxa
rownames(taxa.print) <- NULL
head(taxa.print)
write.csv(taxa, "taxonomy_table_forward_only.csv")
saveRDS(taxa, "taxonomy_forward_only.rds")
tax_summary <- data.frame(
Level = colnames(taxa),
Assigned_ASVs = colSums(!is.na(taxa))
)
tax_summary
write.csv(tax_summary, "taxonomy_assignment_summary.csv", row.names = FALSE)
metadata <- read.csv("metadata.csv", row.names = 1)
metadata
library(phyloseq)
library(ggplot2)
library(vegan)
library(dplyr)
library(tidyr)
library(tibble)
otu <- otu_table(seqtab.nochim, taxa_are_rows = FALSE)
tax <- tax_table(taxa)
sam <- sample_data(metadata)
ps <- phyloseq(otu, tax, sam)
rownames(seqtab.nochim)
rownames(metadata)
rownames(seqtab.nochim) <- gsub("_F_filt.fastq.gz", "", rownames(seqtab.nochim), fixed = TRUE)
rownames(seqtab.nochim)
rownames(metadata)
all(rownames(seqtab.nochim) == rownames(metadata))
otu <- otu_table(seqtab.nochim, taxa_are_rows = FALSE)
tax <- tax_table(taxa)
sam <- sample_data(metadata)
ps <- phyloseq(otu, tax, sam)
ps
saveRDS(ps, "phyloseq_forward_only_object.rds")
alpha_div <- estimate_richness(
ps,
measures = c("Observed", "Shannon", "Simpson")
)
alpha_div$SampleID <- rownames(alpha_div)
metadata2 <- metadata
metadata2$SampleID <- rownames(metadata2)
alpha_div_meta <- merge(alpha_div, metadata2, by = "SampleID")
alpha_div_meta
write.csv(alpha_div_meta, "alpha_diversity_results.csv", row.names = FALSE)
ggplot(alpha_div_meta, aes(x = SampleID, y = Shannon)) +
geom_col(fill = "forestgreen") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(
title = "Shannon Diversity per Sample",
x = "Sample",
y = "Shannon Diversity Index"
)
ggsave("shannon_diversity_per_sample.png", width = 8, height = 5, dpi = 300)
ggplot(alpha_div_meta, aes(x = SampleID, y = Observed)) +
geom_col(fill = "steelblue") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(
title = "Observed ASV Richness per Sample",
x = "Sample",
y = "Observed ASVs"
)
ggsave("observed_richness_per_sample.png", width = 8, height = 5, dpi = 300)
ggplot(alpha_div_meta, aes(x = SampleID, y = Simpson)) +
geom_col(fill = "darkorange") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(
title = "Simpson Diversity per Sample",
x = "Sample",
y = "Simpson Diversity Index"
)
ggsave("simpson_diversity_per_sample.png", width = 8, height = 5, dpi = 300)
ps_phylum <- tax_glom(ps, taxrank = "Phylum")
ps_phylum_rel <- transform_sample_counts(ps_phylum, function(x) x / sum(x))
plot_bar(ps_phylum_rel, x = "SampleID", fill = "Phylum") +
theme_minimal() +
labs(
title = "Relative Abundance of Microbial Phyla Across Samples",
x = "Sample",
y = "Relative Abundance"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
plot_bar(ps_phylum_rel, x = "Run", fill = "Phylum") +
theme_minimal() +
labs(
title = "Relative Abundance of Microbial Phyla Across Samples",
x = "Sample",
y = "Relative Abundance"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggsave("phylum_relative_abundance.png", width = 9, height = 5, dpi = 300)
metadata$SampleID <- rownames(metadata)
sample_data(ps) <- sample_data(metadata)
sample_data(ps)
ps_phylum <- tax_glom(ps, taxrank = "Phylum")
ps_phylum_rel <- transform_sample_counts(ps_phylum, function(x) x / sum(x))
plot_bar(ps_phylum_rel, x = "SampleID", fill = "Phylum") +
theme_minimal() +
labs(
title = "Relative Abundance of Microbial Phyla Across Samples",
x = "Sample",
y = "Relative Abundance"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggsave("phylum_relative_abundance.png", width = 9, height = 5, dpi = 300)
ps_genus <- tax_glom(ps, taxrank = "Genus")
ps_genus_rel <- transform_sample_counts(ps_genus, function(x) x / sum(x))
genus_df <- psmelt(ps_genus_rel)
head(genus_df)
top10_genera <- genus_df %>%
filter(!is.na(Genus)) %>%
group_by(Genus) %>%
summarise(MeanAbundance = mean(Abundance, na.rm = TRUE)) %>%
arrange(desc(MeanAbundance)) %>%
slice_head(n = 10) %>%
pull(Genus)
genus_df_top10 <- genus_df %>%
mutate(Genus = ifelse(Genus %in% top10_genera, Genus, "Others"))
ggplot(genus_df_top10, aes(x = SampleID, y = Abundance, fill = Genus)) +
geom_bar(stat = "identity") +
theme_minimal() +
labs(
title = "Top 10 Microbial Genera Across Samples",
x = "Sample",
y = "Relative Abundance"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggsave("top10_genera_relative_abundance.png", width = 10, height = 5, dpi = 300)
bray_dist <- phyloseq::distance(ps, method = "bray")
ord_pcoa <- ordinate(ps, method = "PCoA", distance = bray_dist)
plot_ordination(ps, ord_pcoa, color = "SampleID") +
geom_point(size = 4) +
theme_minimal() +
labs(
title = "PCoA Plot Based on Bray-Curtis Dissimilarity",
color = "Sample"
)
ggsave("bray_curtis_pcoa_samplewise.png", width = 7, height = 5, dpi = 300)
top_genera_table <- genus_df %>%
filter(!is.na(Genus)) %>%
group_by(Genus) %>%
summarise(
Mean_Relative_Abundance = mean(Abundance, na.rm = TRUE),
Max_Relative_Abundance = max(Abundance, na.rm = TRUE)
) %>%
arrange(desc(Mean_Relative_Abundance)) %>%
slice_head(n = 15)
top_genera_table
write.csv(top_genera_table, "top_15_genera_table.csv", row.names = FALSE)
phylum_df <- psmelt(ps_phylum_rel)
top_phyla_table <- phylum_df %>%
filter(!is.na(Phylum)) %>%
group_by(Phylum) %>%
summarise(
Mean_Relative_Abundance = mean(Abundance, na.rm = TRUE),
Max_Relative_Abundance = max(Abundance, na.rm = TRUE)
) %>%
arrange(desc(Mean_Relative_Abundance))
top_phyla_table
write.csv(top_phyla_table, "top_phyla_table.csv", row.names = FALSE)
write.csv(alpha_div_meta, "alpha_diversity_results.csv", row.names = FALSE)
alpha_div_meta
setwd("D:/Dixcy")
sra <- read.csv("SraRunTable.csv")
names(sra)
metadata_updated <- sra %>%
filter(Run %in% rownames(seqtab.nochim)) %>%
select(
SampleID = Run,
Run,
LibraryName = Library.Name,
SampleName = Sample.Name,
Replicate = replicate,
Tissue = isolation_source,
Host = Host
)
metadata_updated$Condition <- ifelse(
grepl("^SW", metadata_updated$LibraryName),
"SW_control",
ifelse(
grepl("^FW", metadata_updated$LibraryName) & !grepl("^FWD", metadata_updated$LibraryName),
"SFW_intermediate",
"FW_stress"
)
)
metadata_updated$Condition <- ifelse(
grepl("^SW", metadata_updated$SampleName),
"SW_control",
ifelse(
grepl("^SFW", metadata_updated$SampleName),
"SFW_intermediate",
"FW_stress"
)
)
metadata_updated$Stress <- ifelse(
metadata_updated$Condition == "SW_control",
"Seawater_control",
ifelse(
metadata_updated$Condition == "SFW_intermediate",
"Intermediate_hypotonic_stress",
"Freshwater_hypotonic_stress"
)
)
rownames(metadata_updated) <- metadata_updated$SampleID
metadata_updated$SampleID <- rownames(metadata_updated)
metadata_updated
write.csv(metadata_updated, "metadata_updated.csv", row.names = TRUE)
metadata <- read.csv("metadata_updated.csv", row.names = 1)
sample_data(ps) <- sample_data(metadata)
sample_data(ps)
alpha_div <- estimate_richness(
ps,
measures = c("Observed", "Shannon", "Simpson")
)
alpha_div$SampleID <- rownames(alpha_div)
metadata2 <- as.data.frame(sample_data(ps))
metadata2$SampleID <- rownames(metadata2)
alpha_div_meta <- merge(alpha_div, metadata2, by = "SampleID")
alpha_div <- estimate_richness(
ps,
measures = c("Observed", "Shannon", "Simpson")
)
alpha_div$SampleID <- rownames(alpha_div)
metadata2 <- data.frame(sample_data(ps))
metadata2$SampleID <- rownames(metadata2)
alpha_div_meta <- dplyr::left_join(
alpha_div,
metadata2,
by = "SampleID"
)
alpha_div_meta
write.csv(alpha_div_meta, "alpha_diversity_by_condition.csv", row.names = FALSE)
ggplot(alpha_div_meta, aes(x = Condition, y = Observed, fill = Condition)) +
geom_boxplot(alpha = 0.7) +
geom_jitter(width = 0.15, size = 3) +
theme_minimal() +
labs(
title = "Observed ASV Richness Across Osmotic Conditions",
x = "Condition",
y = "Observed ASVs"
)
ggsave("richness_by_condition.png", width = 8, height = 5, dpi = 300)
ggplot(alpha_div_meta, aes(x = Condition, y = Shannon, fill = Condition)) +
geom_boxplot(alpha = 0.7) +
geom_jitter(width = 0.15, size = 3) +
theme_minimal() +
labs(
title = "Shannon Diversity Across Osmotic Conditions",
x = "Condition",
y = "Shannon Diversity Index"
)
ggsave("shannon_by_condition.png", width = 8, height = 5, dpi = 300)
ggplot(alpha_div_meta, aes(x = Condition, y = Simpson, fill = Condition)) +
geom_boxplot(alpha = 0.7) +
geom_jitter(width = 0.15, size = 3) +
theme_minimal() +
labs(
title = "Simpson Diversity Across Osmotic Conditions",
x = "Condition",
y = "Simpson Diversity Index"
)
ggsave("simpson_by_condition.png", width = 8, height = 5, dpi = 300)
bray_dist <- phyloseq::distance(ps, method = "bray")
ord_pcoa <- ordinate(ps, method = "PCoA", distance = bray_dist)
plot_ordination(ps, ord_pcoa, color = "Condition") +
geom_point(size = 4) +
theme_minimal() +
labs(
title = "PCoA Plot of Gill Microbiome Across Osmotic Conditions",
color = "Condition"
)
ggsave("pcoa_by_condition.png", width = 7, height = 5, dpi = 300)
otu_mat <- as(otu_table(ps), "matrix")
if (taxa_are_rows(ps)) {
otu_mat <- t(otu_mat)
}
meta_df <- data.frame(sample_data(ps))
adonis_condition <- adonis2(
otu_mat ~ Condition,
data = meta_df,
method = "bray",
permutations = 999
)
adonis_condition
write.csv(as.data.frame(adonis_condition), "PERMANOVA_condition_results.csv")
alpha_summary <- alpha_div_meta %>%
group_by(Condition) %>%
summarise(
Mean_Richness = mean(Observed),
SD_Richness = sd(Observed),
Mean_Shannon = mean(Shannon),
SD_Shannon = sd(Shannon),
Mean_Simpson = mean(Simpson),
SD_Simpson = sd(Simpson),
n = n()
)
alpha_summary
write.csv(alpha_summary, "alpha_diversity_summary_by_condition.csv", row.names = FALSE)
genus_condition_summary <- genus_df %>%
filter(!is.na(Genus)) %>%
group_by(Condition, Genus) %>%
summarise(
Mean_Relative_Abundance = mean(Abundance, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(Condition, desc(Mean_Relative_Abundance))
top_genera_by_condition <- genus_condition_summary %>%
group_by(Condition) %>%
slice_head(n = 10)
top_genera_by_condition
write.csv(top_genera_by_condition, "top_genera_by_condition.csv", row.names = FALSE)
ggplot(genus_df_top10, aes(x = Condition, y = Abundance, fill = Genus)) +
geom_bar(stat = "identity", position = "fill") +
theme_minimal() +
labs(
title = "Top 10 Microbial Genera Across Osmotic Conditions",
x = "Condition",
y = "Relative Abundance"
)
ggsave("top10_genera_by_condition.png", width = 9, height = 5, dpi = 300)
alpha_summary <- alpha_div_meta %>%
group_by(Condition) %>%
summarise(
Mean_Richness = mean(Observed),
SD_Richness = sd(Observed),
Mean_Shannon = mean(Shannon),
SD_Shannon = sd(Shannon),
Mean_Simpson = mean(Simpson),
SD_Simpson = sd(Simpson),
n = n()
)
alpha_summary
write.csv(alpha_summary, "alpha_diversity_summary_by_condition.csv", row.names = FALSE)
genus_condition_summary <- genus_df %>%
filter(!is.na(Genus)) %>%
group_by(Condition, Genus) %>%
summarise(
Mean_Relative_Abundance = mean(Abundance, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(Condition, desc(Mean_Relative_Abundance))
top_genera_by_condition <- genus_condition_summary %>%
group_by(Condition) %>%
slice_head(n = 10)
top_genera_by_condition
write.csv(top_genera_by_condition, "top_genera_by_condition.csv", row.names = FALSE)
ggplot(genus_df_top10, aes(x = Condition, y = Abundance, fill = Genus)) +
